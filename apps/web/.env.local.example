# AWS Aurora Postgres (Serverless v2), region us-west-1.
# Use the RDS Proxy endpoint, NOT the cluster endpoint, so Vercel Fluid
# Compute functions pool connections through the Proxy.
DATABASE_URL=postgres://app:REPLACE_ME@odosan-proxy.proxy-XXXXXXXX.us-west-1.rds.amazonaws.com:5432/odosan?sslmode=require

# better-auth
BETTER_AUTH_URL=http://localhost:4000
BETTER_AUTH_SECRET=REPLACE_ME_32_BYTE_RANDOM

# Optional — Anything platform / mobile proxy URLs. Only needed if you build
# the Expo app or run the social-dev-shim. Leaving these unset is fine.
# EXPO_PUBLIC_PROXY_BASE_URL=
# NEXT_PUBLIC_CREATE_BASE_URL=
# NEXT_PUBLIC_CREATE_HOST=

# Optional — social providers self-register when both id + secret are set.
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# APPLE_CLIENT_ID=
# APPLE_CLIENT_SECRET=
# APPLE_APP_BUNDLE_IDENTIFIER=
